KIE_API_KEY=replace_with_your_kie_api_key
KIE_BASE_URL=https://api.kie.ai
KIE_UPLOAD_BASE_URL=https://kieai.redpandaai.co

# Optional live integration test controls.
RUN_KIE_LIVE_TESTS=0
KIE_LIVE_SCOPE=all
KIE_LIVE_POLL_INTERVAL=10
KIE_LIVE_TIMEOUT=900

# Required only when running Suno live tests.
KIE_SUNO_CALLBACK_URL=https://example.com/kie/suno-callback
